# Copy to .env and fill in real values.
# Never commit .env — it contains credentials.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Full Npgsql connection string. The DB and schema must already exist.
# In Docker, use host.docker.internal to reach Postgres running on the host
# (whether bare-metal or as a Docker container exposed on the host port).
POSTGRES_CONNECTION_STRING=Host=host.docker.internal;Port=5432;Database=mydb;Username=nik;Password=mysecretpassword

# ── Keycloak ──────────────────────────────────────────────────────────────────
# Public URL — must match the `iss` claim in every JWT.
# This is what the browser uses for OIDC redirects and what the backend uses
# as the expected issuer when validating tokens (string comparison, no DNS).
KEYCLOAK_AUTHORITY=https://keycloak.test.local/realms/mes-realm

# Internal URL — used only by the backend to fetch the JWKS (public keys) for
# JWT signature verification. Must be a URL the backend container can actually
# reach over the network. Use host.docker.internal when Keycloak is exposed on
# the host's port 8080 (the typical Docker-based Keycloak setup).
KEYCLOAK_BACKCHANNEL_AUTHORITY=http://host.docker.internal:8080/realms/mes-realm

# Keycloak client ID — must match the client created in Keycloak and the
# audience mapper on that client.
KEYCLOAK_CLIENT_ID=mes-frontend

# ── Frontend ──────────────────────────────────────────────────────────────────
# Host port for the nginx container (default 80).
# Run a TLS-terminating proxy (existing nginx, Traefik, cloud LB) in front
# for HTTPS — the MES container speaks plain HTTP only.
HTTP_PORT=8090
